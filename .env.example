# --- Streamlit app (primary deploy) ---
GROQ_API_KEY=gsk_...
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL_SMALL=BAAI/bge-small-en-v1.5
EMBEDDING_MODEL_LARGE=BAAI/bge-large-en-v1.5
CHROMA_PERSIST_DIR=./data/chroma
METADATA_DB_PATH=./data/metadata.db
# Persistent chat history (mount a volume at /data in production).
CHAT_HISTORY_PATH=./data/chat_history.json
LOG_LEVEL=INFO
# Lower memory on Railway / Streamlit Cloud (auto-enabled on Railway if unset).
BGE_KEEP_SINGLE_MODEL=true
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=1
# Set to true only if Groww fetches must go through HTTP(S)_PROXY.
FETCH_TRUST_ENV=false

# --- OpenAI embeddings (optional alternative to local BGE) ---
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small

# --- Legacy FastAPI + Next.js stack (optional) ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated production frontend origins allowed by CORS (e.g. Vercel URL).
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=
# Background warmup at API startup only (not used by Streamlit — it warms via @st.cache_resource).
WARMUP_ON_STARTUP=true
