GROQ_API_KEY=gsk_...
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL_SMALL=BAAI/bge-small-en-v1.5
EMBEDDING_MODEL_LARGE=BAAI/bge-large-en-v1.5
EMBEDDING_MODEL=text-embedding-3-small
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0
CHROMA_PERSIST_DIR=./data/chroma
METADATA_DB_PATH=./data/metadata.db
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
# Set to true only if Groww fetches must go through HTTP(S)_PROXY.
FETCH_TRUST_ENV=false
# Comma-separated production frontend origins allowed by CORS (e.g. Vercel URL).
# Localhost origins are always allowed. Example:
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=
# Warm up embedding/LLM models at startup (background thread). Disabled by default
# on Railway to avoid OOM restart loops; models load lazily on first request.
WARMUP_ON_STARTUP=true
# Comma-separated BGE model keys to preload when warmup is enabled (default: small only).
# WARMUP_EMBEDDING_MODELS=small
# Keep only one BGE model in memory at a time (auto-enabled on Railway).
# BGE_KEEP_SINGLE_MODEL=true
